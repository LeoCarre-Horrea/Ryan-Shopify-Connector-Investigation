# Copy this file to .env and fill in the values (never commit .env)
#
#   cp scripts/.env.example scripts/.env

# Store domain (with or without https://)
SHOPIFY_STORE=fanshopaperol.myshopify.com

# Custom app credentials (Shopify Admin → Settings → Develop apps → your app → Credentials)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=shpss_

# Optional
SHOPIFY_API_VERSION=2026-01
